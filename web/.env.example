# Guardar / leer métricas en Vercel Blob (necesario para “Guardar en la nube” desde el navegador)
# Crear token en: Vercel → Storage → Blob → Connect
BLOB_READ_WRITE_TOKEN=

# Secreto para PUT /api/metrics (Authorization: Bearer <SAVE_METRICS_SECRET>)
SAVE_METRICS_SECRET=

# Opcional: pathname del JSON en Blob (por defecto coo-metricas/metrics.json)
# METRICS_BLOB_PATHNAME=
